# ── Supabase ───────────────────────────────────────────────────────────────────
# supabase.com → Your Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Hostinger SMTP (your existing email) ───────────────────────────────────────
# Use any email already on your Hostinger account
# Hostinger SMTP settings: smtp.hostinger.com / port 465 / SSL
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@veksol.com
SMTP_PASS=your_hostinger_email_password

# ── Anthropic API (VEMBOT AI) ───────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── JWT Secret ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-random-secret-minimum-32-characters-long

# ── Google Sheets API (service account) ────────────────────────────────────────
# Go to: console.cloud.google.com → IAM → Service Accounts → Create → JSON key
# Paste the ENTIRE JSON as a single-line string (stringify it first)
# Then share each doctor's Google Sheet with the service account email
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"vektor-sheets@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── Vercel Cron Secret ────────────────────────────────────────────────────────
# Any random string — protects /api/cron/refreshSheets from public access
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=your_random_cron_secret_here
